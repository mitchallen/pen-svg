{
  "name": "@mitchallen/pen-svg",
  "version": "0.2.7",
  "description": "pen to svg file",
  "main": "index-factory.js",
  "scripts": {
    "//": "To use: npm run test-nodemon (assumes global location of mocha)",
    "start": "node index.js",
    "test": "mocha --recursive --timeout 20000",
    "test-nodemon": "nodemon /usr/local/bin/mocha --timeout 5000",
    "test-debug": "nodemon /usr/local/bin/mocha -g '@DEBUG' --recursive --timeout 20000",
    "test-jenkins": "mocha --recursive --timeout 20000 -R xunit test/ > test-reports.xml",
    "preversion": "npm test",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchallen/pen-svg.git"
  },
  "author": "Mitch Allen <npm@mitchallen.com> (http://mitchallen.com)",
  "license": "MIT",
  "dependencies": {
    "@mitchallen/demand": "^0.1.3",
    "@mitchallen/factory-base": "0.1.0",
    "@mitchallen/fuse-svg-path": "^0.1.4",
    "@mitchallen/pen": "^0.2.6",
    "chance": "^1.1.8"
  },
  "devDependencies": {
    "mocha": "^11.7.6",
    "should": "^10.0.0",
    "supertest": "^6.1.6"
  },
  "overrides": {
    "mocha": {
      "serialize-javascript": "^7.0.5",
      "js-yaml": "^4.1.1"
    }
  }
}
